---
import type { Tianguis } from '../../types/tianguis';
import { formatLocation } from '../../services/tianguis';

interface Props {
  tianguis: Tianguis;
}

const { tianguis: t } = Astro.props;
const hasCoordinates = Number.isFinite(t.lat) && Number.isFinite(t.lng) && t.lat !== 0 && t.lng !== 0;
const mapFocusId = `${t.name}-${t.lat}-${t.lng}`;
---

<div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-4 hover:shadow-lg transition-shadow border border-gray-100 dark:border-gray-700">
  <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-2">
    {t.name}
  </h3>
  <div class="space-y-1 text-sm text-gray-600 dark:text-gray-400">
    <p class="flex items-start">
      <svg class="w-4 h-4 mr-2 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      <span>{formatLocation(t.location)}</span>
    </p>
    <p class="flex items-center">
      <svg class="w-4 h-4 mr-2 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      <span class="capitalize">{t.day}</span>
    </p>
    <p class="text-xs text-gray-500 dark:text-gray-500 mt-2">
      {t.municipality.charAt(0).toUpperCase() + t.municipality.slice(1)}, {t.state}
    </p>
  </div>

  {hasCoordinates && (
    <button
      type="button"
      class="js-focus-map-btn mt-4 w-full px-3 py-2 rounded-md text-sm font-medium text-blue-700 dark:text-blue-300 bg-blue-50 dark:bg-blue-900/30 hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-colors"
      data-focus-id={mapFocusId}
      data-focus-name={t.name}
      data-focus-lat={String(t.lat)}
      data-focus-lng={String(t.lng)}
    >
      Ver en mapa
    </button>
  )}
</div>
