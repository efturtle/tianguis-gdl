---
import { TianguisService, formatLocation } from '../services/tianguis';
import type { Tianguis } from '../types/tianguis';

interface Props {
  municipality?: string;
  day?: string;
}

const { municipality, day } = Astro.props;

// Fetch tianguis data based on filters
let tianguis: Tianguis[] = [];

if (municipality && day) {
  // Both filters: specific municipality and day
  tianguis = await TianguisService.getTianguis({ 
    municipality, 
    day: day as any,
    state: 'jalisco'
  });
} else if (municipality) {
  // Only municipality: all days for that municipality
  tianguis = await TianguisService.getTianguisByMunicipality('jalisco', municipality);
} else if (day) {
  // Only day: all municipalities for that day
  tianguis = await TianguisService.getTianguis({ 
    day: day as any,
    state: 'jalisco'
  });
} else {
  // No filters: default to guadalajara
  tianguis = await TianguisService.getTianguisByMunicipality('jalisco', 'guadalajara');
}
---

<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
  {tianguis.map((t: Tianguis) => (
    <div class="bg-white rounded-lg shadow-md p-4 hover:shadow-lg transition-shadow">
      <h3 class="text-lg font-bold text-gray-900 mb-2">
        {t.name}
      </h3>
      <div class="space-y-1 text-sm text-gray-600">
        <p class="flex items-start">
          <svg class="w-4 h-4 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span>{formatLocation(t.location)}</span>
        </p>
        <p class="flex items-center">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <span class="capitalize">{t.day}</span>
        </p>
        <p class="text-xs text-gray-500 mt-2">
          {t.municipality.charAt(0).toUpperCase() + t.municipality.slice(1)}, {t.state}
        </p>
      </div>
    </div>
  ))}
</div>

{tianguis.length === 0 && (
  <div class="text-center py-12 text-gray-500">
    <p class="text-lg">No se encontraron tianguis</p>
  </div>
)}
