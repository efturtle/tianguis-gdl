---
import Base from './base.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
}

const { title, description, image, type } = Astro.props;
---

<Base title={title} description={description} image={image} type={type}>
  <div class="flex min-h-screen bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50">
    <Sidebar />
    <main class="flex-1 p-8">
      <slot />
    </main>
  </div>
</Base>
