---
import Base from '../layouts/base.astro';
import Sidebar from '../components/ui/Sidebar.astro';
import SearchDashboard from '../components/ui/SearchDashboard.vue';
import Map from '../components/map/Map.vue';
import MobileMapView from '../components/ui/MobileMapView.vue';
import { TianguisService } from '../services/tianguis';

// Get filtered tianguis for this municipality and day
const tianguis = await TianguisService.getTianguis({ 
  state: 'jalisco'
});

// Prepare data for map
const tianguisData = tianguis.map(t => ({
  name: t.name,
  lat: t.lat,
  lng: t.lng,
  day: t.day,
  municipality: t.municipality,
  state: t.state,
  location: t.location,
  direccion: t.location.type === 'address' ? t.location.direccion : null,
  street1: t.location.type === 'streets' ? t.location.street1 : null,
  street2: t.location.type === 'streets' ? t.location.street2 : null,
}));
---

<Base title="Tianguis GDL - Encuentra tianguis cerca de ti">
    <div class="md:flex min-h-screen md:bg-linear-to-br md:from-blue-50 md:via-indigo-50 md:to-purple-100 dark:md:from-gray-800 dark:md:via-gray-700 dark:md:to-gray-900">
        <div class="hidden md:block">
            <Sidebar />
        </div>
        
        <div class="block md:hidden flex-1 min-h-screen">
            <MobileMapView client:only="vue" tianguis={tianguisData} />
        </div>

        <div class="hidden md:flex flex-1 gap-6 h-screen p-8 overflow-hidden">
            <div class="w-100 shrink-0 flex items-center justify-center">
                <div class="text-center px-6">
                    <div class="mb-6">
                        <svg class="w-20 h-20 text-gray-400 dark:text-gray-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </div>
                    <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-3">
                        Bienvenido a Tianguis GDL
                    </h1>
                    <p class="text-gray-600 dark:text-gray-400 mb-6">
                        Selecciona una ciudad o día de la semana desde el menú lateral para ver los tianguis disponibles en el mapa.
                    </p>
                    <div class="flex flex-col gap-3 text-sm text-gray-500 dark:text-gray-400">
                        <div class="flex items-center justify-center gap-2">
                            <span class="text-blue-500 dark:text-blue-400">🏙️</span>
                            <span>Filtra por ciudad</span>
                        </div>
                        <div class="flex items-center justify-center gap-2">
                            <span class="text-purple-500 dark:text-purple-400">📅</span>
                            <span>Filtra por día</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="hidden md:flex flex-1 min-h-0 rounded-2xl overflow-hidden shadow-md">
                <Map tianguis={tianguisData} client:only="vue" />
            </div>
        </div>
    </div>
</Base>