---
import WithSidebar from '../layouts/with-sidebar.astro';
import TianguisList from '../components/TianguisList.astro';
import { MUNICIPALITIES } from '../config/municipalities';
---

<WithSidebar title="Tianguis GDL - Encuentra tianguis en Guadalajara y Zapopan">
	<div class="max-w-7xl">
		<div class="mb-8">
			<h1 class="text-4xl font-bold text-gray-900 mb-4">
				Bienvenido a Tianguis GDL
			</h1>
			<p class="text-lg text-gray-600 mb-6">
				Encuentra los mejores tianguis en Guadalajara y Zapopan organizados por día y ubicación.
			</p>
			
			<div class="flex gap-4 flex-wrap">
				{MUNICIPALITIES.map((municipality) => (
					<a 
						href={`/${municipality.slug}`}
						class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium shadow-md hover:shadow-lg"
					>
						Ver tianguis en {municipality.name}
					</a>
				))}
			</div>
		</div>

		<div class="mt-12">
			<h2 class="text-2xl font-bold text-gray-900 mb-6">
				Tianguis en Guadalajara
			</h2>
			<TianguisList municipality="guadalajara" />
		</div>
	</div>
</WithSidebar>
