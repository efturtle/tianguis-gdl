---
import WithSidebar from '../../layouts/with-sidebar.astro';
import TianguisList from '../../components/tianguis/TianguisList.astro';
import Map from '../../components/map/Map.vue';
import { MUNICIPALITIES, getMunicipalityBySlug } from '../../config/municipalities';
import { TianguisService } from '../../services/tianguis';

const days = [
  { name: 'Lunes', slug: 'lunes' },
  { name: 'Martes', slug: 'martes' },
  { name: 'Miércoles', slug: 'miercoles' },
  { name: 'Jueves', slug: 'jueves' },
  { name: 'Viernes', slug: 'viernes' },
  { name: 'Sábado', slug: 'sabado' },
  { name: 'Domingo', slug: 'domingo' },
];

export function getStaticPaths() {
  const paths = [];
  
  const daysArray = [
    { name: 'Lunes', slug: 'lunes' },
    { name: 'Martes', slug: 'martes' },
    { name: 'Miércoles', slug: 'miercoles' },
    { name: 'Jueves', slug: 'jueves' },
    { name: 'Viernes', slug: 'viernes' },
    { name: 'Sábado', slug: 'sabado' },
    { name: 'Domingo', slug: 'domingo' },
  ];
  
  for (const municipality of MUNICIPALITIES) {
    for (const day of daysArray) {
      paths.push({
        params: { 
          municipality: municipality.slug,
          day: day.slug 
        },
        props: { 
          municipality,
          day 
        },
      });
    }
  }
  
  return paths;
}

const { municipality, day } = Astro.props;
const municipalityData = getMunicipalityBySlug(municipality.slug);
const dayName = days.find(d => d.slug === day.slug)?.name || day.slug;

if (!municipalityData) {
  return Astro.redirect('/');
}

// Get filtered tianguis for this municipality and day
const tianguis = await TianguisService.getTianguis({ 
  municipality: municipalityData.slug,
  day: day.slug as any,
  state: 'jalisco'
});

// Prepare data for map
const tianguisData = tianguis.map(t => ({
  name: t.name,
  lat: t.lat,
  lng: t.lng,
  day: t.day,
  municipality: t.municipality,
  location: t.location,
  direccion: t.location.type === 'address' ? t.location.direccion : null,
  street1: t.location.type === 'streets' ? t.location.street1 : null,
  street2: t.location.type === 'streets' ? t.location.street2 : null,
}));

const tianguisWithCoords = tianguisData.filter(t => t.lat && t.lng).length;
---

<WithSidebar 
  title={`Tianguis los ${dayName} en ${municipalityData.name} - Tianguis GDL`}
  description={`Tianguis que operan los ${dayName.toLowerCase()} en ${municipalityData.name}, ${municipalityData.state}`}
>
  <div class="max-w-7xl">
    <div class="mb-6">
      <div class="flex gap-2 mb-3">
        <span class="inline-block px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm font-medium">
          {municipalityData.name}
        </span>
        <span class="inline-block px-3 py-1 bg-purple-100 text-purple-800 rounded-full text-sm font-medium">
          {dayName}
        </span>
      </div>
      <h1 class="text-4xl font-bold text-gray-900 mb-2 dark:text-gray-100">
        Tianguis los {dayName}
      </h1>
      <p class="text-lg text-gray-600 mb-4 dark:text-gray-300">
        {municipalityData.name}, {municipalityData.state}
      </p>
      
      <div class="flex items-center justify-between">
        <div class="text-sm text-gray-600 dark:text-gray-400">
          📍 {tianguisWithCoords} tianguis en el mapa
        </div>
        
        <div class="flex gap-3 text-sm">
          <a 
            href={`/${municipalityData.slug}`}
            class="text-blue-600 hover:text-blue-800 hover:underline dark:hover:text-blue-400"
          >
            ← Todos los días
          </a>
          <span class="text-gray-400 dark:text-gray-600">|</span>
          <a 
            href={`/day/${day.slug}`}
            class="text-blue-600 hover:text-blue-800 hover:underline dark:hover:text-blue-400"
          >
            Todos los municipios →
          </a>
        </div>
      </div>
    </div>

    <!-- Map Section -->
    <div class="mb-8 bg-white dark:bg-gray-800 rounded-lg shadow-lg p-4" style="height: 450px;">
      <Map client:only="vue" tianguis={tianguisData} initialZoom={13} />
    </div>

    <!-- List Section -->
    <div class="mb-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-4 dark:text-gray-100">
        Lista de Tianguis
      </h2>
      <TianguisList municipality={municipalityData.slug} day={day.slug} />
    </div>
  </div>
</WithSidebar>
