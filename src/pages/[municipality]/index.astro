---
import WithSidebar from '../../layouts/with-sidebar.astro';
import TianguisList from '../../components/tianguis/TianguisList.astro';
import Map from '../../components/map/Map.vue';
import { MUNICIPALITIES, getMunicipalityBySlug } from '../../config/municipalities';
import { TianguisService } from '../../services/tianguis';

export function getStaticPaths() {
  return MUNICIPALITIES.map((municipality) => ({
    params: { municipality: municipality.slug },
  }));
}

// Get municipality from params, not props
const { municipality: municipalitySlug } = Astro.params;

// Validate param exists
if (!municipalitySlug) {
  console.error('Missing municipality param');
  return Astro.redirect('/');
}

const municipalityData = getMunicipalityBySlug(municipalitySlug);

if (!municipalityData) {
  console.error('Municipality not found:', municipalitySlug);
  return Astro.redirect('/');
}

// Get tianguis for this municipality
const tianguis = await TianguisService.getTianguisByMunicipality('jalisco', municipalityData.slug);

// Prepare data for map
const tianguisData = tianguis.map(t => ({
  name: t.name,
  lat: t.lat,
  lng: t.lng,
  day: t.day,
  municipality: t.municipality,
  state: t.state,
  location: t.location,
  direccion: t.location.type === 'address' ? t.location.direccion : null,
  street1: t.location.type === 'streets' ? t.location.street1 : null,
  street2: t.location.type === 'streets' ? t.location.street2 : null, 
}));

const tianguisWithCoords = tianguisData.filter(t => t.lat && t.lng).length;
---

<WithSidebar 
  title={`Tianguis en ${municipalityData.name} - Tianguis GDL`}
  description={`Encuentra todos los tianguis en ${municipalityData.name}, ${municipalityData.state} organizados por día de la semana`}
>
  <div class="max-w-7xl">
    <div class="mb-8">
      <h1 class="text-4xl font-bold text-gray-900 mb-2 dark:text-gray-100">
        Tianguis en {municipalityData.name}
      </h1>
      <p class="text-lg text-gray-600 mb-4 dark:text-gray-400">
        {municipalityData.state}
      </p>
      
      <div class="text-sm text-gray-600 dark:text-gray-400">
        📍 {tianguisWithCoords} tianguis con ubicación en el mapa
      </div>
    </div>

    <!-- Map Section -->
    <div class="mb-8 bg-white dark:bg-gray-800 rounded-lg shadow-lg p-4" style="height: 500px;">
      <Map tianguis={tianguisData} client:only="vue" initialZoom={12} />
    </div>

    <!-- List Section -->
    <div class="mb-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-4 dark:text-gray-100">
        Lista de Tianguis
      </h2>
      <TianguisList municipality={municipalityData.slug} />
    </div>
  </div>
</WithSidebar>

<script>
  // Check if viewport is mobile (< 768px based on Tailwind's md breakpoint)
  function isMobile() {
    return window.innerWidth < 768;
  }

  // Redirect to home if mobile
  function checkAndRedirect() {
    if (isMobile()) {
      window.location.href = '/';
    }
  }

  // Check on initial load
  checkAndRedirect();

  // Listen for resize events with debouncing
  let resizeTimer: number;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(() => {
      checkAndRedirect();
    }, 250);
  });
</script>
