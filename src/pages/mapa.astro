---
import Base from '../layouts/base.astro';
import MobileMap from '../components/map/MobileMap.vue';
import { TianguisService } from '../services/tianguis';

// Get filtered tianguis for this municipality and day
const tianguis = await TianguisService.getTianguis({ 
  state: 'jalisco'
});

// Prepare data for map
const tianguisData = tianguis.map(t => ({
  name: t.name,
  lat: t.lat,
  lng: t.lng,
  day: t.day,
  municipality: t.municipality,
  state: t.state,
  location: t.location,
  distance: t.distance,
  direccion: t.location.type === 'address' ? t.location.direccion : null,
  street1: t.location.type === 'streets' ? t.location.street1 : null,
  street2: t.location.type === 'streets' ? t.location.street2 : null,
}));

const pageTitle = 'Mapa de Tianguis - Tianguis GDL';
const pageDescription = 'Visualiza todos los tianguis de Guadalajara y Zapopan en el mapa';
---

<Base 
  title={pageTitle}
  description={pageDescription}
>
  <MobileMap 
    tianguis={tianguisData}
    client:only="vue"
  />
</Base>

<style>
  /* Remove any default body padding/margin for full-screen map */
  :global(body) {
    margin: 0;
    padding: 0;
    overflow: hidden;
  }
</style>
